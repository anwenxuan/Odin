{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["repo_path", "entrypoints"],
  "properties": {
    "repo_path": { "type": "string" },
    "entrypoints": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Entry point identifiers, e.g. ['handlers/auth.py::login']"
    },
    "max_depth": {
      "type": "integer",
      "minimum": 1,
      "default": 8
    }
  }
}
