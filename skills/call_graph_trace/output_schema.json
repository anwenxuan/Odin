{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["call_edges", "hot_paths", "evidence_refs"],
  "properties": {
    "call_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["caller", "callee", "confidence", "evidence_refs"],
        "properties": {
          "caller": { "type": "string" },
          "callee": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "guard_present": { "type": "boolean" },
          "file_path": { "type": "string" },
          "line_start": { "type": "integer" },
          "snippet": { "type": "string" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "MEU refs in format: file_path::symbol:line"
          }
        }
      }
    },
    "hot_paths": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Sequences of function calls forming a high-value execution path"
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_edges": { "type": "integer" },
        "max_depth_reached": { "type": "integer" },
        "entrypoints_covered": { "type": "integer" }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
