{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["dependencies", "risk_flags", "evidence_refs"],
  "properties": {
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "file_path", "confidence", "evidence_refs"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "file_path": { "type": "string" },
          "type": { "type": "string" },
          "is_direct": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dependency_name", "flag_type", "description", "evidence_refs"],
        "properties": {
          "dependency_name": { "type": "string" },
          "flag_type": { "type": "string", "enum": ["outdated", "known_cve", "unmaintained", "malicious", "license_risk"] },
          "cve_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "description": { "type": "string" },
          "recommended_version": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    },
    "evidence_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  }
}
