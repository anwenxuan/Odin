# Environment Variables Template

# LLM Provider Configuration
# Choose one:
#   - OPENAI_API_KEY  (GPT-4o, GPT-4-turbo)
#   - ANTHROPIC_API_KEY  (Claude 3.5 Sonnet, etc.)

OPENAI_API_KEY=your-openai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Model Configuration
# MODEL=gpt-4o
# TEMPERATURE=0.0
# MAX_TOKENS=4096

# Workflow Configuration
# MAX_CALL_GRAPH_DEPTH=8
# WORKFLOW_TIMEOUT_SEC=300

# Persistence
# EVIDENCE_STORE_PATH=./data/evidence
# MEMORY_STORE_PATH=./data/memory
